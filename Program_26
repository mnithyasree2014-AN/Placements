#Fibonacci series

package Placement;

public class prgm26 {

	    public static void main(String[] args) {
	        int first = 0, second = 1;

	        System.out.println("Fibonacci Series up to 10:");

	        while (first <= 10) {
	            System.out.print(first + " ");

	            int next = first + second;
	            first = second;
	            second = next;
	        }
	    }
	}
