#Check whether the given sting is same or not

package Placement;

public class prgm16 {

	public static void main(String[] args) {
	StringBuffer sb1 = new StringBuffer("Hello");
	StringBuffer sb2 = sb1;
	sb1.append(" world");
	if(sb1 == sb2)
		System.out.println("Same");
	else
		System.out.println("Not Same");

	}

}
