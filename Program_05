#Find avg for the array

package Placement;

public class prgm5{

	public static void main(String[] args) {
		        int a[] = {10, 30, 30, 50, 20};

		        int sum = 0;

		        for (int i = 0; i < a.length; i++) {
		            sum += a[i];
		        }

		        double avg = (double) sum / a.length;

		        System.out.println("Average = " + avg);
		    }
		}
